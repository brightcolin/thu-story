# 《清华园物语》后端环境变量 v2.2

# 【可选】DeepSeek API 密钥；留空时使用离线降级回复
DEEPSEEK_API_KEY=

# 【必需】前端访问令牌
# 仅用于本地联调；公网部署必须替换为随机长令牌
API_TOKEN=local-dev-token-change-me

# 【可选】服务器
HOST=0.0.0.0
PORT=8000
DEBUG=false

# 【可选】数据库路径
QINGHUA_DB_PATH=qinghua_story.db

# 【可选】跨域
ALLOWED_ORIGINS=*

# 部署注意：
# 1. Windows pm2: pm2 start main.py --name thustory-api --interpreter .\venv\Scripts\python.exe
# 2. 需设置 PYTHONIOENCODING=utf-8
# 3. pip 用清华镜像: -i https://pypi.tuna.tsinghua.edu.cn/simple
